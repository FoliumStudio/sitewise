# Files and folders that must NOT be deployed to the WordPress.org SVN repo.
# Used by 10up/action-wordpress-plugin-deploy. The deployed slug is
# `wp-call-me-back` (Sitewise is the display name; the slug is fixed forever).

# Version control / CI / dev tooling
/.git
/.github
/.gitignore
/.distignore
/.editorconfig
/phpcs.xml
/phpcs.xml.dist
/_config.yml

# Local-only helpers and build output
/scripts
/dist
/build
/node_modules
/.idea
/.sass-cache

# Cloudflare Worker — shipped/deployed separately, not part of the WP plugin zip
/worker

# Project docs (developer-facing, not shipped to users)
/CONCEPT.md
/CONCEPT.html
/scrape.md
/roadmap.md
/*.md
/TODO.md
/to-do
/CHANGELOG.md
/Folium Suite - Standalone.html

# wp.org listing assets (published to SVN /assets by the deploy action, NOT shipped in the plugin zip)
/.wordpress-org

# Local scratch / working notes
/to-add or fix

# OS cruft
.DS_Store
*/.DS_Store
Thumbs.db
*/Thumbs.db
